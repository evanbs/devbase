{
  "name": "{{PROJECT_NAME}}",
  "dockerComposeFile": "docker-compose.yml",
  "service": "app",
  "workspaceFolder": "/workspace",

  // ── Stack features (uncomment what the project needs) ──────────────────
  "features": {
    // "ghcr.io/devcontainers/features/java:1": { "version": "21" },
    // "ghcr.io/devcontainers/features/python:1": { "version": "3.12" },
    // "ghcr.io/devcontainers/features/rust:1": {},
    // "ghcr.io/devcontainers/features/android:1": {}
  },

  // ── Forwarded ports (uncomment what the project needs) ─────────────────
  "forwardPorts": [
    // 3000,   // web / Next.js / React
    // 8080,   // API / Spring Boot
    // 5432,   // PostgreSQL
    // 6379,   // Redis
    // 27017,  // MongoDB
    // 9001    // MinIO console (http://localhost:9001 — user/pass: devlocal)
  ],

  // ── VS Code extensions ──────────────────────────────────────────────────
  "customizations": {
    "vscode": {
      "extensions": [
        "EditorConfig.EditorConfig",
        "esbenp.prettier-vscode",
        "dbaeumer.vscode-eslint",
        "eamodio.gitlens",
        "humao.rest-client"
      ],
      "settings": {
        "terminal.integrated.defaultProfile.linux": "zsh",
        "terminal.integrated.profiles.linux": {
          "zsh": { "path": "zsh", "args": ["-l"] }
        },
        "editor.formatOnSave": true
      }
    }
  },

  // ── Post-create setup ──────────────────────────────────────────────────
  "postCreateCommand": "command -v devbase-setup >/dev/null 2>&1 && devbase-setup || true",

  // ── Environment variables ──────────────────────────────────────────────
  "remoteEnv": {
    "AWS_ACCESS_KEY_ID":            "devlocal",
    "AWS_SECRET_ACCESS_KEY":        "devlocal",
    "AWS_DEFAULT_REGION":           "us-east-1",
    "AWS_ENDPOINT_URL_DYNAMODB":    "http://dynamodb:8000",
    "AWS_ENDPOINT_URL_S3":          "http://minio:9000"
    // Variáveis de projeto (use localEnv — nunca hardcode):
    // "ANTHROPIC_API_KEY": "${localEnv:ANTHROPIC_API_KEY}",
    // "GH_TOKEN":          "${localEnv:GH_TOKEN}"
  }
}
